# Dependencies
node_modules/

# Build output
dist/

# Local data & auth
store/
data/
logs/

# Groups - only track the *global* templates. groups/main/CLAUDE.md was
# previously tracked but composeGroupClaudeMd rewrites it deterministically
# on every spawn (3-line includes scaffold), clobbering the seed and showing
# up as noise in `git status`. The agent never read the seed anyway — the
# global CLAUDE.md is reached via the @./.claude-shared.md symlink to
# /workspace/global/CLAUDE.md. Per-group CLAUDE.md is now a runtime artifact.
groups/*
!groups/main/
!groups/global/
groups/main/*
groups/global/*
!groups/global/CLAUDE.md
!groups/global/IDENTITY.md

# Secrets
*.keys.json
.env

# MCP configuration (modified by skill installations)
.mcp.json

# OS
.DS_Store
socket:*

# Runtime artifacts from setup script's WSL/nohup fallback path
start-nanotars.sh
nanotars.pid

# IDE
.idea/
.vscode/

agents-sdk-docs

# Internal plans
docs/plans/

# Plugins (personal config, created by skills)
plugins/*
!plugins/.gitkeep
# Core plugins — ship with repo
!plugins/agent-browser/
# Channel plugins — installed from skill templates, not committed
!plugins/channels/
plugins/channels/*
!plugins/channels/.gitkeep

